# ====================================
# Options API Configuration
# ====================================

# API Provider Selection
# Options: backend, polygon, yahoo, tradier, mock
#
# - backend: (RECOMMENDED) Uses local Node.js server for fast scanning
#            Falls back to Polygon.io if server unavailable
#            Run: cd server && npm install && npm start
#
# - polygon: Polygon.io API (free tier: 5 calls/min, ~2-3 tickers/min)
#            Falls back to backend if available
#
# - yahoo: Yahoo Finance via CORS proxy (often blocked)
#
# - tradier: Tradier API (requires paid subscription for options)
#
# - mock: Simulated data for testing/development
#
VITE_OPTIONS_API_PROVIDER=backend

# ====================================
# Backend Server Configuration
# ====================================
# Local server URL (defaults to http://localhost:3001)
# The backend server provides fast, unlimited scanning via Yahoo Finance
# VITE_BACKEND_URL=http://localhost:3001

# ====================================
# Polygon.io Configuration
# ====================================
# Sign up at: https://polygon.io/
# Free tier: 5 API calls/minute (slow but works)
# Used as fallback when backend server is unavailable
VITE_POLYGON_API_KEY=your_polygon_api_key_here

# ====================================
# Finnhub Configuration
# ====================================
# Sign up at: https://finnhub.io/
# Free tier: 60 API calls/minute
# Used for: Trending stocks, stock quotes
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# ====================================
# Tradier Configuration (Optional)
# ====================================
# Sign up at: https://documentation.tradier.com/
# Note: Options data requires paid subscription
# VITE_TRADIER_API_KEY=your_tradier_api_key_here
# VITE_TRADIER_SANDBOX=true
